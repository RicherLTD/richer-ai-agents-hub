# Supabase — client-side (safe to commit; this file is the template, not real values)
# Real values go in .env.local (which is gitignored).
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Server-side only (DO NOT commit, DO NOT prefix with VITE_)
# Used by local scripts (db:apply, prompts sync). Never include in client code.
SUPABASE_PROJECT_REF=YOUR-PROJECT-REF
SUPABASE_ACCESS_TOKEN=sbp_...
# SUPABASE_SERVICE_ROLE_KEY=
