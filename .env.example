# Template for .env.local — copy to .env.local and fill in real values for
# anything you need to override or for server-only secrets.
#
# Public Supabase values (URL + publishable key) live in `.env` and are
# committed to git — they're designed by Supabase to be public, so all
# environments (local, Lovable, CI) share them. RLS protects the data.
#
# This file is the place for SECRETS that must never be committed.

# Server-side only — used by scripts/db/apply.ts and future sync scripts.
# Generate at https://supabase.com/dashboard/account/tokens
SUPABASE_PROJECT_REF=YOUR-PROJECT-REF
SUPABASE_ACCESS_TOKEN=sbp_...

# Service-role key — bypasses RLS. Only used by server scripts. Never in
# client code, never prefixed with VITE_.
# SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────────────
# HookMyApp / WhatsApp sandbox (consumed by `whatsapp-webhook` and
# `whatsapp-send` edge functions). Pull session values with:
#   hookmyapp sandbox env --write .env.functions.local
# Then serve functions with:
#   bunx supabase functions serve --env-file .env.functions.local
# For deployed functions, push as Supabase secrets:
#   bunx supabase secrets set --env-file .env.functions.local
# ─────────────────────────────────────────────────────────────────────
# VERIFY_TOKEN=
# WHATSAPP_API_URL=https://sandbox.hookmyapp.com/v22.0
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# Slug from public.agents.name to attribute inbound sandbox messages to.
# HOOKMYAPP_AGENT_NAME=affiliate_marketing
# Anthropic API key — drives the autonomous agent reply loop in
# `whatsapp-webhook`. Without it, inbound messages still land in the DB
# but the bot doesn't reply.
# ANTHROPIC_API_KEY=sk-ant-...
